---
// src/components/Concierge.astro
import contatti from '../data/contatti.json';
import traduzioni from '../data/traduzioni.json';
const currentPath = Astro.url.pathname;

type Lang = 'it' | 'en' | 'de';
let lang: Lang = 'it';

if (currentPath.startsWith('/en')) lang = 'en';
if (currentPath.startsWith('/de')) lang = 'de';

const t = {
    it: { title: traduzioni.it.concierge_titolo, roomService: traduzioni.it.concierge_room, roomServiceSub: traduzioni.it.concierge_room_sub, reception: traduzioni.it.concierge_rec, receptionSub: traduzioni.it.concierge_rec_sub, wa_room: traduzioni.it.wa_room_service },
    en: { title: traduzioni.en.concierge_titolo, roomService: traduzioni.en.concierge_room, roomServiceSub: traduzioni.en.concierge_room_sub, reception: traduzioni.en.concierge_rec, receptionSub: traduzioni.en.concierge_rec_sub, wa_room: traduzioni.en.wa_room_service },
    de: { title: traduzioni.de.concierge_titolo, roomService: traduzioni.de.concierge_room, roomServiceSub: traduzioni.de.concierge_room_sub, reception: traduzioni.de.concierge_rec, receptionSub: traduzioni.de.concierge_rec_sub, wa_room: traduzioni.de.wa_room_service }
};
---

<div class="fixed bottom-24 right-4 md:bottom-12 md:right-12 z-50" id="concierge-wrapper" transition:persist="concierge">
    
    <div id="concierge-menu" class="absolute bottom-full right-0 mb-4 w-60 bg-[#0a0a0a]/95 backdrop-blur-xl border border-[#d4af37]/30 rounded-2xl p-2 opacity-0 invisible translate-y-4 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)]">
        <div class="p-4 border-b border-white/10 mb-2">
            <h4 class="text-[#d4af37] text-xs tracking-[0.2em] uppercase font-bold" style="font-family: 'Space Grotesk', sans-serif;">{t[lang].title}</h4>
        </div>
        
        <div class="space-y-1">
            <a href={`https://wa.me/${contatti.whatsapp}?text=${encodeURIComponent(t[lang].wa_room)}`} target="_blank" class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors">
                <div class="w-10 h-10 rounded-full bg-[#25D366]/20 flex items-center justify-center text-[#25D366] flex-shrink-0">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                </div>
                <div>
                    <div class="text-white text-[11px] uppercase tracking-widest" style="font-family: 'Space Grotesk', sans-serif;">{t[lang].roomService}</div>
                    <div class="text-gray-500 text-[9px] uppercase tracking-widest">{t[lang].roomServiceSub}</div>
                </div>
            </a>
            
            <a href={`tel:+${contatti.whatsapp}`} class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors">
                <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white flex-shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </div>
                <div>
                    <div class="text-white text-[11px] uppercase tracking-widest" style="font-family: 'Space Grotesk', sans-serif;">{t[lang].reception}</div>
                    <div class="text-gray-500 text-[9px] uppercase tracking-widest">{t[lang].receptionSub}</div>
                </div>
            </a>
        </div>
    </div>

    <button id="concierge-btn" class="relative w-14 h-14 md:w-16 md:h-16 flex-shrink-0 aspect-square bg-gradient-to-tr from-[#d4af37] to-[#e8cb69] rounded-full flex items-center justify-center text-black shadow-[0_0_20px_rgba(212,175,55,0.4)] hover:shadow-[0_0_30px_rgba(212,175,55,0.6)] hover:scale-105 transition-all duration-300 z-50 cursor-pointer">
        <svg id="concierge-icon-open" class="w-6 h-6 md:w-8 md:h-8 absolute transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <svg id="concierge-icon-close" class="w-6 h-6 md:w-8 md:h-8 absolute opacity-0 rotate-90 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
</div>

<script>
    const setupConcierge = () => {
        const btn = document.getElementById('concierge-btn');
        const menu = document.getElementById('concierge-menu');
        const iconOpen = document.getElementById('concierge-icon-open');
        const iconClose = document.getElementById('concierge-icon-close');
        
        if(btn && menu && btn.getAttribute('data-init') !== 'true') {
            btn.setAttribute('data-init', 'true');
            let isOpen = false;

            const toggleMenu = (e: Event) => {
                e.stopPropagation();
                isOpen = !isOpen;
                
                if (isOpen) {
                    menu.classList.remove('opacity-0', 'invisible', 'translate-y-4');
                    iconOpen?.classList.add('opacity-0', '-rotate-90');
                    iconClose?.classList.remove('opacity-0', 'rotate-90');
                } else {
                    menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
                    iconOpen?.classList.remove('opacity-0', '-rotate-90');
                    iconClose?.classList.add('opacity-0', 'rotate-90');
                }
            };

            btn.addEventListener('click', toggleMenu);

            document.addEventListener('click', (e) => {
                if (isOpen && !menu.contains(e.target as Node) && e.target !== btn) {
                    isOpen = false;
                    menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
                    iconOpen?.classList.remove('opacity-0', '-rotate-90');
                    iconClose?.classList.add('opacity-0', 'rotate-90');
                }
            });
        }
    };
    
    setupConcierge();
    document.addEventListener('astro:page-load', setupConcierge);
</script>