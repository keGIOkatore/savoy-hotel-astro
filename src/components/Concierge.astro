---
// src/components/Concierge.astro
const currentPath = Astro.url.pathname;

type Lang = 'it' | 'en' | 'de';
let lang: Lang = 'it';

if (currentPath.startsWith('/en')) lang = 'en';
if (currentPath.startsWith('/de')) lang = 'de';

const t = {
    it: {
        title: 'Il tuo Concierge',
        roomService: 'Servizio in Camera',
        roomServiceSub: 'Risposta in 2 min',
        reception: 'Chiama Reception',
        receptionSub: 'Disponibile 24/7'
    },
    en: {
        title: 'Your Concierge',
        roomService: 'Room Service',
        roomServiceSub: 'Replies in 2 mins',
        reception: 'Call Reception',
        receptionSub: 'Available 24/7'
    },
    de: {
        title: 'Ihr Concierge',
        roomService: 'Zimmerservice',
        roomServiceSub: 'Antwort in 2 Min.',
        reception: 'Rezeption Anrufen',
        receptionSub: '24/7 Verfügbar'
    }
};
---

<div class="fixed bottom-24 right-4 md:bottom-12 md:right-12 z-50 group" id="concierge-wrapper">
    
    <div id="concierge-menu" class="absolute bottom-full right-0 pb-4 w-64 opacity-0 invisible transform translate-y-4 md:group-hover:opacity-100 md:group-hover:visible md:group-hover:translate-y-0 transition-all duration-300">
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 p-4 rounded-2xl flex flex-col gap-2 shadow-2xl pointer-events-auto">
            <p class="text-[#d4af37] text-[9px] tracking-[0.3em] uppercase mb-2 ml-2" style="font-family: 'Space Grotesk', sans-serif;">
                {t[lang].title}
            </p>
            <a href="https://wa.me/390431430144" target="_blank" class="flex items-center gap-4 text-white hover:bg-white/10 active:bg-white/10 p-3 rounded-xl transition-colors">
                <div class="bg-[#25D366]/20 p-2 rounded-full text-[#25D366]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-xs tracking-wider font-light">{t[lang].roomService}</span>
                    <span class="text-[9px] text-gray-400">{t[lang].roomServiceSub}</span>
                </div>
            </a>
            <a href="tel:+390431430144" class="flex items-center gap-4 text-white hover:bg-white/10 active:bg-white/10 p-3 rounded-xl transition-colors">
                <div class="bg-white/10 p-2 rounded-full text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div class="flex flex-col">
                    <span class="text-xs tracking-wider font-light">{t[lang].reception}</span>
                    <span class="text-[9px] text-[#d4af37]">{t[lang].receptionSub}</span>
                </div>
            </a>
        </div>
    </div>

    <button id="concierge-btn" class="relative z-10 w-14 h-14 bg-gradient-to-tr from-[#d4af37] to-[#e5c158] rounded-full flex items-center justify-center text-black shadow-[0_0_20px_rgba(212,175,55,0.4)] md:hover:scale-110 active:scale-95 transition-all duration-300 pointer-events-auto">
        <svg class="w-6 h-6 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
    </button>
</div>

<style>
    .mobile-open {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) !important;
    }
</style>

<script>
    const setupConcierge = () => {
        const btn = document.getElementById('concierge-btn');
        const menu = document.getElementById('concierge-menu');
        const wrapper = document.getElementById('concierge-wrapper');

        if(btn && menu && wrapper) {
            // Se non l'abbiamo già attivato, lo attiviamo (evita cloni e reset)
            if (!btn.hasAttribute('data-init')) {
                btn.setAttribute('data-init', 'true');
                
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    menu.classList.toggle('mobile-open');
                });

                document.addEventListener('click', (e) => {
                    if (!wrapper.contains(e.target as Node)) {
                        menu.classList.remove('mobile-open');
                    }
                });
            }
        }
    };
    setupConcierge();
    document.addEventListener('astro:page-load', setupConcierge);
</script>