---
// src/components/OrarioBadge.astro
import orariRaw from '../data/orari.json';
const orariData: any = orariRaw;

interface Props {
  type: 'ristorante' | 'spa';
  lang: 'it' | 'en' | 'de';
}

const { type, lang } = Astro.props;

const translations = {
  it: { open: 'Aperto Ora', closed: 'Chiuso' },
  en: { open: 'Open Now', closed: 'Closed' },
  de: { open: 'Jetzt Geöffnet', closed: 'Geschlossen' }
};

const textOpen = translations[lang].open;
const textClosed = translations[lang].closed;

// Peschiamo i numeri dal file orari.json (con valori di sicurezza se mancano)
const times = {
  risto_pranzo_ap: orariData.risto_pranzo_ap || 12.5,
  risto_pranzo_ch: orariData.risto_pranzo_ch || 14.5,
  risto_cena_ap: orariData.risto_cena_ap || 19.5,
  risto_cena_ch: orariData.risto_cena_ch || 22.5,
  spa_ap: orariData.spa_ap || 9.0,
  spa_ch: orariData.spa_ch || 20.0,
};
---

<orario-badge data-type={type} data-open={textOpen} data-closed={textClosed} data-times={JSON.stringify(times)} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[9px] tracking-[0.2em] uppercase font-bold mt-3 shadow-lg">
  <span class="status-dot w-2 h-2 rounded-full bg-gray-600 animate-pulse shadow-[0_0_8px_rgba(255,255,255,0.2)]"></span>
  <span class="status-text text-gray-400">...</span>
</orario-badge>

<script>
  class OrarioBadge extends HTMLElement {
    connectedCallback() {
      const type = this.dataset.type;
      const textOpen = this.dataset.open || '';
      const textClosed = this.dataset.closed || '';
      
      // Recuperiamo i numeri magici che hai impostato nel CMS
      const times = JSON.parse(this.dataset.times || '{}');

      const dot = this.querySelector('.status-dot') as HTMLElement | null;
      const text = this.querySelector('.status-text') as HTMLElement | null;
      
      const checkStatus = () => {
        const now = new Date();
        const hour = now.getHours() + (now.getMinutes() / 60);
        let isOpen = false;
        
        if (type === 'ristorante') {
          isOpen = (hour >= times.risto_pranzo_ap && hour < times.risto_pranzo_ch) || 
                   (hour >= times.risto_cena_ap && hour < times.risto_cena_ch);
        } else if (type === 'spa') {
          isOpen = (hour >= times.spa_ap && hour < times.spa_ch);
        }
        
        if (isOpen) {
          if(dot) dot.className = "status-dot w-2 h-2 rounded-full bg-[#25D366] shadow-[0_0_8px_rgba(37,211,102,0.6)]";
          if(text) {
              text.textContent = textOpen;
              text.className = "status-text text-white";
          }
        } else {
          if(dot) dot.className = "status-dot w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]";
          if(text) {
              text.textContent = textClosed;
              text.className = "status-text text-red-400";
          }
        }
      };
      
      checkStatus();
      setInterval(checkStatus, 60000);
    }
  }
  
  if (!customElements.get('orario-badge')) {
    customElements.define('orario-badge', OrarioBadge);
  }
</script>