---
// src/components/BottomNav.astro
const currentPath = Astro.url.pathname;

type Lang = 'it' | 'en' | 'de';
let lang: Lang = 'it';
if (currentPath.startsWith('/en')) lang = 'en';
if (currentPath.startsWith('/de')) lang = 'de';

const labels = {
    it: { home: 'Home', servizi: 'Servizi', spa: 'Thermae', gusto: 'Gusto' },
    en: { home: 'Home', servizi: 'Services', spa: 'Thermae', gusto: 'Dining' },
    de: { home: 'Start', servizi: 'Services', spa: 'Thermae', gusto: 'Genuss' }
};

const prefix = lang === 'it' ? '' : `/${lang}`;

const isHome = currentPath === prefix + '/' || currentPath === prefix || currentPath === '';
const isServizi = currentPath.includes('/servizi');
const isSpa = currentPath.includes('/spa');
const isGusto = currentPath.includes('/ristorante');
---

<nav class="lg:hidden fixed bottom-0 w-full z-50 bg-[#050505]/95 backdrop-blur-md border-t border-white/10 pb-safe pb-2">
    <div class="flex justify-around items-center h-16 px-2">
        
        <a href={prefix || '/'} class:list={["flex flex-col items-center gap-1 w-full h-full justify-center transition-colors", { "text-[#d4af37]": isHome, "text-gray-500 hover:text-gray-300": !isHome }]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="text-[9px] tracking-widest uppercase" style="font-family: 'Space Grotesk', sans-serif;">{labels[lang].home}</span>
        </a>

        <a href={prefix + '/servizi'} class:list={["flex flex-col items-center gap-1 w-full h-full justify-center transition-colors", { "text-[#d4af37]": isServizi, "text-gray-500 hover:text-gray-300": !isServizi }]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
            <span class="text-[9px] tracking-widest uppercase" style="font-family: 'Space Grotesk', sans-serif;">{labels[lang].servizi}</span>
        </a>

        <a href={prefix + '/spa'} class:list={["flex flex-col items-center gap-1 w-full h-full justify-center transition-colors", { "text-[#d4af37]": isSpa, "text-gray-500 hover:text-gray-300": !isSpa }]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <span class="text-[9px] tracking-widest uppercase" style="font-family: 'Space Grotesk', sans-serif;">{labels[lang].spa}</span>
        </a>

        <a href={prefix + '/ristorante'} class:list={["flex flex-col items-center gap-1 w-full h-full justify-center transition-colors", { "text-[#d4af37]": isGusto, "text-gray-500 hover:text-gray-300": !isGusto }]}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 14a7 7 0 0114 0H5zM2 16h20M12 7V4m-2 0h4" />
            </svg>
            <span class="text-[9px] tracking-widest uppercase" style="font-family: 'Space Grotesk', sans-serif;">{labels[lang].gusto}</span>
        </a>

    </div>
</nav>

<script>
    document.addEventListener('contextmenu', event => event.preventDefault());

    const initHaptics = () => {
        const interactables = document.querySelectorAll<HTMLElement>('a, button');
        interactables.forEach(el => {
            if (!el.hasAttribute('data-haptic')) {
                el.setAttribute('data-haptic', 'true');
                el.style.setProperty('-webkit-tap-highlight-color', 'transparent');
                el.addEventListener('touchstart', () => {
                    if (navigator.vibrate) {
                        const testoSulBottone = el.textContent ? el.textContent.toUpperCase() : '';
                        if (el.id === 'concierge-btn') {
                            navigator.vibrate([15, 60, 20]); 
                        } else if (testoSulBottone.includes('PRENOTA') || testoSulBottone.includes('RISERVA')) {
                            navigator.vibrate(25);
                        } else {
                            navigator.vibrate(10);
                        }
                    }
                }, { passive: true });
            }
        });
    };
    initHaptics();
    document.addEventListener('astro:page-load', initHaptics);
</script>