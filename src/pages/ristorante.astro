---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import orariData from '../data/orari.json';

let piatti: any[] = [];
try { piatti = await Astro.glob('../content/ristorante/it/*.md'); } catch (error) {}
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ristorante Duca d'Aosta | SAVOY Beach Hotel</title>
    
    <ViewTransitions />

    <meta name="description" content="Menù degustazione e sapori autentici dell'Adriatico al ristorante gourmet Duca d'Aosta." />
    <link rel="alternate" hreflang="it" href="https://tuosito.com/ristorante" />
    <link rel="alternate" hreflang="en" href="https://tuosito.com/en/ristorante" />
    <link rel="alternate" hreflang="de" href="https://tuosito.com/de/ristorante" />
    <meta property="og:title" content="Ristorante Duca d'Aosta | SAVOY Beach Hotel" />
    <meta property="og:description" content="Menù degustazione e sapori autentici dell'Adriatico al ristorante gourmet." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" />

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-[#050505] text-[#e0e0e0] antialiased selection:bg-white selection:text-black overflow-x-hidden">

    <header class="absolute w-full z-50 top-0 py-8 px-6 md:px-12 flex justify-between items-center bg-gradient-to-b from-black/90 via-black/40 to-transparent">
        
        <nav class="hidden md:flex flex-1 justify-start gap-10 text-white text-xs tracking-[0.25em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
            <a href="/camere" class="hover:text-[#d4af37] transition-colors duration-500">Residenze</a>
            <a href="/spa" class="hover:text-[#d4af37] transition-colors duration-500">Thermae</a>
            <a href="/ristorante" class="hover:text-[#d4af37] transition-colors duration-500">Gusto</a>
        </nav>

        <div class="flex-1 text-center">
            <a href="/" class="inline-block text-5xl tracking-[0.3em] uppercase drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;">
                <span class="text-white font-light">Sav</span><span class="text-[#d4af37] font-semibold italic">oy</span>
            </a>
        </div>
        
        <div class="hidden md:flex flex-1 justify-end items-center gap-10">
            <div class="flex gap-4 text-white/50 text-xs tracking-[0.2em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
                <span class="text-white font-bold border-b-2 border-[#d4af37] pb-1">IT</span>
                <a href="/en/ristorante" class="hover:text-white transition-colors pb-1">EN</a>
                <a href="/de/ristorante" class="hover:text-white transition-colors pb-1">DE</a>
            </div>
            
            <a href="https://www.booking.com/Share-rV0ICW" target="_blank" class="bg-gradient-to-r from-[#d4af37] to-[#c5a028] text-black px-10 py-4 text-xs tracking-[0.3em] uppercase font-bold shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:shadow-[0_0_30px_rgba(212,175,55,0.8)] hover:scale-105 transition-all duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                Prenota
            </a>
        </div>
    </header>

    <section class="relative h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Duca d'Aosta" class="absolute inset-0 w-full h-full object-cover opacity-40 grayscale" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Duca d'Aosta</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-10" style="font-family: 'Cormorant Garamond', serif;">
                <i>Menù</i> Degustazione.
            </h1>
            
            <div class="mt-4 flex flex-col items-center">
                <div class="h-px w-16 bg-[#d4af37]/50 mb-4"></div>
                <span class="text-[#d4af37] text-[10px] tracking-[0.4em] uppercase mb-2" style="font-family: 'Space Grotesk', sans-serif;">Orari di Apertura</span>
                <p class="text-white text-sm md:text-base tracking-[0.15em] font-light uppercase" style="font-family: 'Space Grotesk', sans-serif;">
                    {orariData.it.orari_ristorante}
                </p>
                <div class="h-px w-16 bg-[#d4af37]/50 mt-4"></div>
            </div>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-md mx-auto">
        {piatti.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                Il menù è attualmente in aggiornamento.
            </div>
        ) : (
            <div class="space-y-16">
                {piatti.map((piatto) => {
                    const Content = piatto.Content;
                    return (
                        <div class="border-b border-white/10 pb-12 flex justify-between items-start group hover:border-[#d4af37]/50 transition-colors">
                            <div class="w-3/4 pr-8">
                                <h3 class="text-3xl text-white font-light mb-2 group-hover:text-[#d4af37] transition-colors" style="font-family: 'Cormorant Garamond', serif;">
                                    {piatto.frontmatter.title}
                                </h3>
                                <p class="text-gray-500 text-[10px] tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">
                                    {piatto.frontmatter.categoria}
                                </p>
                                <div class="text-gray-400 font-light text-sm leading-relaxed" style="font-family: 'Space Grotesk', sans-serif;">
                                    <Content />
                                </div>
                            </div>
                            <div class="w-1/4 text-right flex flex-col items-end">
                                <span class="text-2xl md:text-3xl text-white font-light mb-4" style="font-family: 'Cormorant Garamond', serif;">
                                    € {piatto.frontmatter.prezzo}
                                </span>
                                {piatto.frontmatter.image && (
                                    <img src={piatto.frontmatter.image} alt="Piatto" class="w-24 h-24 object-cover rounded-full opacity-70 grayscale group-hover:grayscale-0 group-hover:opacity-100 transition duration-500" />
                                )}
                            </div>
                        </div>
                    );
                })}
            </div>
        )}
    </section>

    <footer class="py-12 border-t border-white/10 text-center">
        <p class="text-[#555] text-xs tracking-[0.3em] uppercase" style="font-family: 'Space Grotesk', sans-serif;">
            © 2026 Savoy Beach Hotel.
        </p>
    </footer>
</body>
</html>