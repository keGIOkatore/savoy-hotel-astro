---
// @ts-ignore
import BaseLayout from '../../layouts/BaseLayout.astro';
// @ts-ignore
import menuRaw from '../../data/menu_duca.json';

const menuData = menuRaw as { categorie: { nome: string; piatti: { nome: string; descrizione: string; prezzo: number }[] }[] };
---

<BaseLayout title="Duca D'Aosta Menü" description="Das saisonale Menü des Gourmetrestaurants Duca D'Aosta." lang="de" currentPath="/menu">
    
    <section class="relative h-[40vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Duca D'Aosta" class="absolute inset-0 w-full h-full object-cover opacity-30 pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-20">
            <p class="text-[#d4af37] text-xs md:text-sm tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Gourmetrestaurant</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-6 drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;">
                <i>Duca</i> D'Aosta.
            </h1>
        </div>
    </section>

    <section class="py-24 px-6 max-w-screen-md mx-auto space-y-24">
        {menuData.categorie.map(categoria => (
            <div>
                <h2 class="text-4xl md:text-5xl text-white font-light text-center mb-16 italic" style="font-family: 'Cormorant Garamond', serif;">
                    {categoria.nome}
                </h2>
                <div class="space-y-12">
                    {categoria.piatti.map(piatto => (
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 md:gap-8 group">
                            <div class="flex-1">
                                <h3 class="text-lg md:text-xl text-white font-medium tracking-wide mb-2 transition-colors group-hover:text-[#d4af37]" style="font-family: 'Cormorant Garamond', serif;">
                                    {piatto.nome}
                                </h3>
                                <p class="text-gray-400 text-xs md:text-sm font-light leading-relaxed max-w-sm" style="font-family: 'Space Grotesk', sans-serif;">
                                    {piatto.descrizione}
                                </p>
                            </div>
                            <div class="w-full md:w-auto flex items-center gap-4 mt-2 md:mt-0">
                                <div class="flex-1 md:hidden border-b border-white/10 border-dashed mt-4"></div>
                                <span class="text-[#d4af37] text-sm md:text-base font-medium tracking-widest" style="font-family: 'Space Grotesk', sans-serif;">
                                    € {piatto.prezzo}
                                </span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ))}
    </section>
</BaseLayout>