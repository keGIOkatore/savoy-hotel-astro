---
// @ts-ignore
import BaseLayout from '../../layouts/BaseLayout.astro';
import homeData from '../../data/home.json';
---

<BaseLayout title="SAVOY Beach Hotel & Thermal Spa" description="Eine Oase des Luxus und Wohlbefindens. Ganzjährig geöffnet in Bibione." lang="de" currentPath="/">

    <section class="relative min-h-[100svh] flex flex-col justify-center items-center overflow-hidden text-center px-4 py-32 lg:py-0">
        <img src={homeData.hero_image} alt="Savoy Dark" class="absolute inset-0 w-full h-full object-cover opacity-40 scale-105 pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-[#050505]"></div>
        
        <div class="relative z-10 mt-16 hero-content-box transition-all duration-500">
            <h1 class="text-7xl md:text-9xl text-white font-light tracking-widest uppercase mb-4 drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;" set:html={homeData.de.hero_titolo}></h1>
            <p class="text-white/90 text-sm md:text-xl tracking-[0.4em] uppercase font-light" style="font-family: 'Space Grotesk', sans-serif;" set:html={homeData.de.hero_sottotitolo}></p>
            <div class="w-px h-24 bg-white/30 mx-auto mt-12"></div>
        </div>
    </section>

    <section class="relative py-32 px-6 max-w-screen-2xl mx-auto flex flex-col md:flex-row gap-20">
        <div class="md:w-1/2">
            <div class="sticky top-32 h-[70vh] overflow-hidden">
                <img loading="lazy" src={homeData.immagine_servizi} alt="I Nostri Servizi" class="w-full h-full object-cover transition duration-1000 pointer-events-none">
            </div>
        </div>
        <div class="md:w-1/2 flex flex-col justify-center pt-20 md:pt-0">
            <p class="text-[#d4af37] text-[10px] md:text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;" set:html={homeData.de.servizi_occhiello}></p>
            <h2 class="text-5xl md:text-7xl text-white font-light leading-none mb-12" style="font-family: 'Cormorant Garamond', serif;" set:html={homeData.de.servizi_titolo}></h2>
            <div class="space-y-8 text-sm md:text-lg lg:text-xl font-light text-gray-400 leading-relaxed max-w-lg" style="font-family: 'Space Grotesk', sans-serif;">
                <p set:html={homeData.de.servizi_descrizione}></p>
                <div class="pt-8 border-t border-gray-800">
                    <a href="/de/servizi" class="text-white text-xs md:text-sm tracking-[0.3em] uppercase flex items-center gap-4 hover:gap-8 transition-all">
                        {homeData.de.servizi_bottone} <span class="w-12 h-[1px] bg-white block"></span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="relative py-32 px-6 max-w-screen-2xl mx-auto flex flex-col md:flex-row-reverse items-center gap-20">
        <div class="md:w-1/2">
            <div class="relative overflow-hidden h-[60vh] md:h-[80vh]">
                <img loading="lazy" src={homeData.immagine_spa} alt="Thermal Spa" class="w-full h-full object-cover transition duration-1000 pointer-events-none">
            </div>
        </div>
        <div class="md:w-1/2 flex flex-col justify-center">
            <p class="text-[#d4af37] text-[10px] md:text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;" set:html={homeData.de.spa_occhiello}></p>
            <h2 class="text-5xl md:text-7xl text-white font-light leading-none mb-12" style="font-family: 'Cormorant Garamond', serif;" set:html={homeData.de.spa_titolo}></h2>
            <div class="space-y-8 text-sm md:text-lg lg:text-xl font-light text-gray-400 leading-relaxed max-w-lg" style="font-family: 'Space Grotesk', sans-serif;">
                <p set:html={homeData.de.spa_descrizione}></p>
                <div class="pt-8 border-t border-gray-800">
                    <a href="/de/spa" class="text-white text-xs md:text-sm tracking-[0.3em] uppercase flex items-center gap-4 hover:gap-8 transition-all">
                        {homeData.de.spa_bottone} <span class="w-12 h-[1px] bg-white block"></span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="relative py-32 px-6 max-w-screen-2xl mx-auto flex flex-col md:flex-row gap-20 border-b border-white/10">
        <div class="md:w-1/2">
            <div class="relative overflow-hidden h-[60vh] md:h-[80vh]">
                <img loading="lazy" src={homeData.immagine_ristorante} alt="Ristorante" class="w-full h-full object-cover transition duration-1000 pointer-events-none">
            </div>
        </div>
        <div class="md:w-1/2 flex flex-col justify-center">
            <p class="text-[#d4af37] text-[10px] md:text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;" set:html={homeData.de.ristorante_occhiello}></p>
            <h2 class="text-5xl md:text-7xl text-white font-light leading-none mb-12" style="font-family: 'Cormorant Garamond', serif;" set:html={homeData.de.ristorante_titolo}></h2>
            <div class="space-y-8 text-sm md:text-lg lg:text-xl font-light text-gray-400 leading-relaxed max-w-lg" style="font-family: 'Space Grotesk', sans-serif;">
                <p set:html={homeData.de.ristorante_descrizione}></p>
                <div class="pt-8 border-t border-gray-800">
                    <a href="/de/ristorante" class="text-white text-xs md:text-sm tracking-[0.3em] uppercase flex items-center gap-4 active:gap-8 md:hover:gap-8 transition-all">
                        {homeData.de.ristorante_bottone} <span class="w-12 h-[1px] bg-white block"></span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-xl mx-auto">
        <div class="text-center mb-24">
            <p class="text-[#d4af37] text-[10px] md:text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;" set:html={homeData.de.attenzioni_occhiello}></p>
            <h2 class="text-4xl md:text-6xl text-white font-light" style="font-family: 'Cormorant Garamond', serif;" set:html={homeData.de.attenzioni_titolo}></h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-16 gap-x-8 text-center" style="font-family: 'Space Grotesk', sans-serif;">
            
            <a href={homeData.de.box1_link} class="group block cursor-pointer">
                <svg class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-6 text-gray-400 group-hover:text-[#d4af37] group-hover:scale-110 transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <circle cx="12" cy="12" r="5" stroke-width="1"/><path stroke-width="1" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </svg>
                <h3 class="text-white text-[11px] md:text-[13px] tracking-widest uppercase mb-2 transition-colors group-hover:text-[#d4af37]">{homeData.de.box1_titolo}</h3>
                <p class="text-gray-500 text-[10px] uppercase tracking-wider">{homeData.de.box1_sub}</p>
            </a>

            <a href={homeData.de.box2_link} class="group block cursor-pointer">
                <svg class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-6 text-gray-400 group-hover:text-[#d4af37] group-hover:scale-110 transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-width="1" stroke-linecap="round" stroke-linejoin="round" d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/>
                </svg>
                <h3 class="text-white text-[11px] md:text-[13px] tracking-widest uppercase mb-2 transition-colors group-hover:text-[#d4af37]">{homeData.de.box2_titolo}</h3>
                <p class="text-gray-500 text-[10px] uppercase tracking-wider">{homeData.de.box2_sub}</p>
            </a>

            <a href={homeData.de.box3_link} class="group block cursor-pointer">
                <svg class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-6 text-gray-400 group-hover:text-[#d4af37] group-hover:scale-110 transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <rect x="3" y="8" width="18" height="4" rx="1" stroke-width="1"/><path stroke-width="1" d="M4 8l2-4h12l2 4M4 12v6a1 1 0 001 1h14a1 1 0 001-1v-6M7 16h.01M17 16h.01"/>
                </svg>
                <h3 class="text-white text-[11px] md:text-[13px] tracking-widest uppercase mb-2 transition-colors group-hover:text-[#d4af37]">{homeData.de.box3_titolo}</h3>
                <p class="text-gray-500 text-[10px] uppercase tracking-wider">{homeData.de.box3_sub}</p>
            </a>

            <a href={homeData.de.box4_link} class="group block cursor-pointer">
                <svg class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-6 text-gray-400 group-hover:text-[#d4af37] group-hover:scale-110 transition-all duration-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="5.5" cy="17.5" r="3.5"/>
                    <circle cx="18.5" cy="17.5" r="3.5"/>
                    <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                </svg>
                <h3 class="text-white text-[11px] md:text-[13px] tracking-widest uppercase mb-2 transition-colors group-hover:text-[#d4af37]">{homeData.de.box4_titolo}</h3>
                <p class="text-gray-500 text-[10px] uppercase tracking-wider">{homeData.de.box4_sub}</p>
            </a>
        </div>
    </section>
</BaseLayout>