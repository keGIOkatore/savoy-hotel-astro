---
import orariData from '../../data/orari.json';
// @ts-ignore
import OrarioBadge from '../../components/OrarioBadge.astro';
// @ts-ignore
import BaseLayout from '../../layouts/BaseLayout.astro';
import contatti from '../../data/contatti.json';

let ristoranti: any[] = [];
try { ristoranti = await Astro.glob('../../content/ristorante/de/*.md'); } catch (error) {}
---

<BaseLayout title="Die Seelen des Geschmacks" description="Entdecken Sie das Restaurant Duca D'Aosta im Savoy Beach Hotel: eine kulinarische Reise durch authentische Aromen." lang="de" currentPath="/ristorante">

    <section class="relative min-h-[100svh] lg:min-h-0 lg:h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 py-32 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Der Geschmack" class="absolute inset-0 w-full h-full object-cover opacity-40 pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Die Kulinarische Reise</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-10" style="font-family: 'Cormorant Garamond', serif;">
                <i>Die Seelen</i> <br> Des Geschmacks.
            </h1>
            
            <div class="mt-4 flex flex-col items-center">
                <div class="h-px w-16 bg-[#d4af37]/50 mb-4"></div>
                <span class="text-[#d4af37] text-[10px] tracking-[0.4em] uppercase mb-2" style="font-family: 'Space Grotesk', sans-serif;">Duca D'Aosta</span>
                <p class="text-white text-xs md:text-sm lg:text-base tracking-[0.15em] font-light uppercase max-w-[280px] md:max-w-md mx-auto" style="font-family: 'Space Grotesk', sans-serif;">
                    Mittag: {orariData.risto_pranzo_ap} - {orariData.risto_pranzo_ch} | Abend: {orariData.risto_cena_ap} - {orariData.risto_cena_ch}
                </p>
                <OrarioBadge type="ristorante" lang="de" />
                <div class="h-px w-16 bg-[#d4af37]/50 mt-4"></div>
            </div>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-xl mx-auto">
        {ristoranti.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                Unsere kulinarischen Erlebnisse werden geladen.
            </div>
        ) : (
            <div class="space-y-32 md:space-y-40">
                {ristoranti.map((ristorante, index) => {
                    const Content = ristorante.Content;
                    return (
                        <div class:list={['group flex flex-col items-center gap-12 md:gap-16', index % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row']}>
                            
                            <div class="w-full md:w-3/5 relative overflow-hidden">
                                {ristorante.frontmatter.image && (
                                    <img loading="lazy" src={ristorante.frontmatter.image} alt={ristorante.frontmatter.title} class="w-full h-[45vh] md:h-[60vh] object-cover opacity-80 group-hover:opacity-100 transition-all duration-[2500ms] ease-out scale-[1.03] group-hover:scale-100 pointer-events-none" />
                                )}
                            </div>
                            
                            <div class="w-full md:w-2/5 flex flex-col justify-center text-left">
                                <h2 class="text-4xl md:text-5xl text-white font-light mb-4" style="font-family: 'Cormorant Garamond', serif;">
                                    {ristorante.frontmatter.title}
                                </h2>
                                
                                <p class="text-[#d4af37] text-[10px] tracking-[0.3em] uppercase mb-8" style="font-family: 'Space Grotesk', sans-serif;">
                                    {ristorante.frontmatter.categoria || 'SAVOY Erlebnis'}
                                </p>
                                
                                <div class="text-gray-400 font-light text-sm leading-relaxed mb-10 prose prose-invert prose-p:m-0" style="font-family: 'Space Grotesk', sans-serif;">
                                    <Content />
                                </div>
                                
                                <div class="mt-2">
                                    {ristorante.frontmatter.link_esterno ? (
                                        <a href={ristorante.frontmatter.link_esterno} target="_blank" class="group/btn inline-flex items-center justify-center md:justify-start gap-4 px-6 py-3 border border-white/20 active:border-[#d4af37] md:hover:border-[#d4af37] transition-all duration-300 cursor-pointer w-full md:w-auto">
                                            <span class="text-white/80 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] text-[10px] tracking-[0.3em] uppercase font-bold transition-colors duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                                                Menü entdecken
                                            </span>
                                            <svg class="w-4 h-4 text-white/40 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] transform group-active/btn:translate-x-2 md:group-hover/btn:translate-x-2 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                        </a>
                                    ) : (
                                        <a href={`https://wa.me/${contatti.whatsapp}?text=Lieber%20Concierge,%20ich%20m%C3%B6chte%20reservieren:%20${ristorante.frontmatter.title}`} target="_blank" class="group/btn inline-flex items-center justify-center md:justify-start gap-4 px-6 py-3 border border-white/20 active:border-[#d4af37] md:hover:border-[#d4af37] transition-all duration-300 cursor-pointer w-full md:w-auto">
                                            <span class="text-white/80 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] text-[10px] tracking-[0.3em] uppercase font-bold transition-colors duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                                                Tisch reservieren
                                            </span>
                                            <svg class="w-4 h-4 text-white/40 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] transform group-active/btn:translate-x-2 md:group-hover/btn:translate-x-2 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    )
                })}
            </div>
        )}
    </section>
</BaseLayout>