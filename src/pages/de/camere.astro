---
import { ViewTransitions } from 'astro:transitions';
import '../../styles/global.css';

let camere: any[] = [];
try {
    // Peschiamo le camere in TEDESCO
    camere = await Astro.glob('../../content/camere/de/*.md');
} catch (error) {
}
---

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Residenzen & Suiten | SAVOY Beach Hotel</title>
    
    <ViewTransitions />

    <meta name="description" content="Entdecken Sie unsere luxuriösen Zimmer und Suiten mit Meerblick in Bibione. Eine Oase für Design und absoluten Komfort." />
    <link rel="alternate" hreflang="it" href="https://tuosito.com/camere" />
    <link rel="alternate" hreflang="en" href="https://tuosito.com/en/camere" />
    <link rel="alternate" hreflang="de" href="https://tuosito.com/de/camere" />
    <meta property="og:title" content="Residenzen & Suiten | SAVOY Beach Hotel" />
    <meta property="og:description" content="Entdecken Sie unsere luxuriösen Zimmer und Suiten mit Meerblick in Bibione." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-[#050505] text-[#e0e0e0] antialiased selection:bg-white selection:text-black overflow-x-hidden">

    <header class="absolute w-full z-50 top-0 py-8 px-6 md:px-12 flex justify-between items-center bg-gradient-to-b from-black/90 via-black/40 to-transparent">
        <nav class="hidden md:flex flex-1 justify-start gap-10 text-white text-xs tracking-[0.25em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
            <a href="/de/camere" class="text-[#d4af37] border-b border-[#d4af37] pb-1">Residenzen</a>
            <a href="/de/spa" class="hover:text-[#d4af37] transition-colors duration-500">Thermen</a>
            <a href="/de/ristorante" class="hover:text-[#d4af37] transition-colors duration-500">Genuss</a>
        </nav>

        <div class="flex-1 text-center">
            <a href="/de/" class="inline-block text-5xl tracking-[0.3em] uppercase drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;">
                <span class="text-white font-light">Sav</span><span class="text-[#d4af37] font-semibold italic">oy</span>
            </a>
        </div>
        
        <div class="hidden md:flex flex-1 justify-end items-center gap-10">
            <div class="flex gap-4 text-white/50 text-xs tracking-[0.2em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
                <a href="/camere" class="hover:text-white transition-colors pb-1">IT</a>
                <a href="/en/camere" class="hover:text-white transition-colors pb-1">EN</a>
                <span class="text-white font-bold border-b-2 border-[#d4af37] pb-1">DE</span>
            </div>
            
            <a href="https://www.booking.com/Share-rV0ICW" target="_blank" class="bg-gradient-to-r from-[#d4af37] to-[#c5a028] text-black px-10 py-4 text-xs tracking-[0.3em] uppercase font-bold shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:shadow-[0_0_30px_rgba(212,175,55,0.8)] hover:scale-105 transition-all duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                Buchen
            </a>
        </div>
    </header>

    <section class="relative h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Residences" class="absolute inset-0 w-full h-full object-cover opacity-30 grayscale" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Ihr Rückzugsort</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-6" style="font-family: 'Cormorant Garamond', serif;">
                <i>Die</i> Residenzen.
            </h1>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-xl mx-auto">
        {camere.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                Wir bereiten unsere eleganten Suiten vor.
            </div>
        ) : (
            <div class="space-y-40">
                {camere.map((camera, index) => {
                    const Content = camera.Content;
                    return (
                        <div class:list={['flex flex-col items-center gap-16', index % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row']}>
                            <div class="md:w-3/5 relative group overflow-hidden">
                                <img src={camera.frontmatter.image} alt={camera.frontmatter.title} class="w-full h-[50vh] md:h-[70vh] object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition duration-1000 scale-105 group-hover:scale-100" />
                            </div>
                            <div class="md:w-2/5 flex flex-col justify-center">
                                <h2 class="text-4xl md:text-5xl text-white font-light mb-4" style="font-family: 'Cormorant Garamond', serif;">
                                    {camera.frontmatter.title}
                                </h2>
                                <p class="text-[#d4af37] text-[10px] tracking-[0.3em] uppercase mb-8" style="font-family: 'Space Grotesk', sans-serif;">
                                    Ab € {camera.frontmatter.prezzo} pro Nacht
                                </p>
                                <div class="text-gray-400 font-light text-sm leading-relaxed mb-10" style="font-family: 'Space Grotesk', sans-serif;">
                                    <Content />
                                </div>
                                <div class="pt-8 border-t border-gray-800">
                                    <a href="#booking" class="text-white text-xs tracking-[0.3em] uppercase flex items-center gap-4 hover:gap-8 transition-all" style="font-family: 'Space Grotesk', sans-serif;">
                                        Jetzt Buchen <span class="w-12 h-[1px] bg-white block"></span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    )
                })}
            </div>
        )}
    </section>

    <footer class="py-12 border-t border-white/10 text-center">
        <p class="text-[#555] text-xs tracking-[0.3em] uppercase" style="font-family: 'Space Grotesk', sans-serif;">
            © 2026 Savoy Beach Hotel.
        </p>
    </footer>

</body>
</html>