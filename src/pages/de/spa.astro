---
import { ViewTransitions } from 'astro:transitions';
import '../../styles/global.css';
import orariData from '../../data/orari.json';
import BottomNav from '../../components/BottomNav.astro';
import Concierge from '../../components/Concierge.astro';
import OrarioBadge from '../../components/OrarioBadge.astro';

let trattamenti: any[] = [];
try { trattamenti = await Astro.glob('../../content/spa/de/*.md'); } catch (error) {}
---

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thermen & Wellness | SAVOY Beach Hotel</title>
    
    <ViewTransitions />

    <meta name="description" content="Entspannen Sie in unserem exklusiven Wellnesscenter mit direktem Zugang zum Heilwasser von Bibione Thermae." />
    <link rel="alternate" hreflang="it" href="https://tuosito.com/spa" />
    <link rel="alternate" hreflang="en" href="https://tuosito.com/en/spa" />
    <link rel="alternate" hreflang="de" href="https://tuosito.com/de/spa" />
    <meta property="og:title" content="Thermen & Wellness | SAVOY Beach Hotel" />
    <meta property="og:description" content="Entspannen Sie in unserem exklusiven Wellnesscenter in Bibione." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icona-192x192.png">
    <meta name="theme-color" content="#050505" />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body class="bg-[#050505] text-[#e0e0e0] antialiased selection:bg-white selection:text-black overflow-x-hidden overscroll-none touch-pan-y select-none">

    <header class="absolute w-full z-50 top-0 py-8 px-6 md:px-12 flex justify-between items-center bg-gradient-to-b from-black/90 via-black/40 to-transparent">
        
        <nav class="hidden md:flex flex-1 justify-start gap-10 text-white text-xs tracking-[0.25em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
            <a href="/de/camere" class="hover:text-[#d4af37] transition-colors duration-500">Residenzen</a>
            <a href="/de/spa" class="text-[#d4af37] border-b border-[#d4af37] pb-1">Thermen</a>
            <a href="/de/ristorante" class="hover:text-[#d4af37] transition-colors duration-500">Genuss</a>
        </nav>

        <div class="flex-1 text-center">
            <a href="/de/" class="inline-block text-5xl tracking-[0.3em] uppercase drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;">
                <span class="text-white font-light">Sav</span><span class="text-[#d4af37] font-semibold italic">oy</span>
            </a>
        </div>
        
        <div class="absolute right-6 top-10 md:relative md:right-0 md:top-0 md:flex-1 flex justify-end items-center gap-8 z-20">
            <div class="relative group cursor-pointer">
                <div class="flex items-center gap-2 text-white font-medium text-xs tracking-[0.2em] uppercase pb-1 border-b border-[#d4af37]" style="font-family: 'Space Grotesk', sans-serif;">
                    <span>DE</span>
                    <svg class="w-3 h-3 text-[#d4af37]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
                
                <div class="absolute right-0 mt-2 w-36 bg-black/90 backdrop-blur-xl border border-white/10 rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 overflow-hidden shadow-2xl">
                    <a href="/spa" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-white/70 hover:text-white hover:bg-white/10 transition-colors border-b border-white/5">Italiano</a>
                    <a href="/en/spa" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-white/70 hover:text-white hover:bg-white/10 transition-colors border-b border-white/5">English</a>
                    <a href="/de/spa" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-[#d4af37] bg-white/5 border-b border-white/5 font-bold">Deutsch</a>
                </div>
            </div>
            
            <a href="https://www.booking.com/Share-rV0ICW" target="_blank" class="hidden md:block bg-gradient-to-r from-[#d4af37] to-[#c5a028] text-black px-10 py-4 text-xs tracking-[0.3em] uppercase font-bold shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:shadow-[0_0_30px_rgba(212,175,55,0.8)] hover:scale-105 transition-all duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                Buchen
            </a>
        </div>
    </header>

    <section class="relative h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Spa Savoy" class="absolute inset-0 w-full h-full object-cover opacity-30 pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Bibione Thermae</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-10" style="font-family: 'Cormorant Garamond', serif;">
                <i>Pure</i> Entspannung.
            </h1>

            <div class="mt-4 flex flex-col items-center">
                <div class="h-px w-16 bg-[#d4af37]/50 mb-4"></div>
                <span class="text-[#d4af37] text-[10px] tracking-[0.4em] uppercase mb-2" style="font-family: 'Space Grotesk', sans-serif;">Öffnungszeiten</span>
                <p class="text-white text-sm md:text-base tracking-[0.15em] font-light uppercase" style="font-family: 'Space Grotesk', sans-serif;">
                    {orariData.de.orari_spa}
                </p>
                <OrarioBadge type="spa" lang="de"/>
                <div class="h-px w-16 bg-[#d4af37]/50 mt-4"></div>
            </div>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-md mx-auto">
        {trattamenti.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                Die Behandlungen werden in Kürze verfügbar sein.
            </div>
        ) : (
            <div class="space-y-16">
                {trattamenti.map((trattamento) => {
                    const Content = trattamento.Content;
                    return (
                        <div class="border-b border-white/10 pb-12 group transition-colors">
                            <h3 class="text-3xl text-white font-light mb-2 md:group-hover:text-[#d4af37] transition-colors" style="font-family: 'Cormorant Garamond', serif;">
                                {trattamento.frontmatter.title}
                            </h3>
                            <p class="text-gray-500 text-[10px] tracking-[0.3em] uppercase mb-6" style="font-family: 'Space Grotesk', sans-serif;">
                                Dauer: {trattamento.frontmatter.durata} Minuten
                            </p>
                            
                            {trattamento.frontmatter.image && (
                                <img loading="lazy" src={trattamento.frontmatter.image} alt={trattamento.frontmatter.title} class="w-full h-64 object-cover opacity-70 mb-8 transition-all duration-700 pointer-events-none" />
                            )}
                            
                            <div class="text-gray-400 font-light text-sm leading-relaxed" style="font-family: 'Space Grotesk', sans-serif;">
                                <Content />
                            </div>
                            
                            <div class="mt-8">
                                <a href={`https://wa.me/390431430144?text=Sehr%20geehrter%20Concierge,%20ich%20möchte%20folgendes%20Erlebnis%20reservieren:%20${trattamento.frontmatter.title}`} target="_blank" class="group/btn inline-flex items-center gap-6 px-8 py-4 border border-white/20 active:border-[#d4af37] md:hover:border-[#d4af37] active:bg-white/5 transition-all duration-300 cursor-pointer">
                                    <span class="text-white/80 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] text-[10px] tracking-[0.3em] uppercase font-light transition-colors duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                                        Erlebnis Reservieren
                                    </span>
                                    <svg class="w-4 h-4 text-white/40 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] transform group-active/btn:translate-x-2 md:group-hover/btn:translate-x-2 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                </a>
                            </div>
                            
                        </div>
                    );
                })}
            </div>
        )}
    </section>

    <footer class="bg-[#030303] pt-24 pb-32 md:pb-12 border-t border-white/10">
        <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-16 mb-16 text-center md:text-left">
            <div>
                <h3 class="text-3xl text-white font-light tracking-widest uppercase mb-6" style="font-family: 'Cormorant Garamond', serif;">
                    Savoy
                </h3>
                <p class="text-gray-400 text-[10px] tracking-[0.2em] uppercase leading-loose" style="font-family: 'Space Grotesk', sans-serif;">
                    Eine Oase von Luxus und Wellness.<br>Ganzjährig geöffnet in Bibione.
                </p>
            </div>
            <div>
                <h4 class="text-[#d4af37] text-[10px] tracking-[0.3em] uppercase mb-6" style="font-family: 'Space Grotesk', sans-serif;">Kontakte</h4>
                <ul class="text-gray-400 text-[11px] tracking-widest font-light space-y-4" style="font-family: 'Space Grotesk', sans-serif;">
                    <li>Corso Europa, 51<br>30028 Bibione (VE) - Italien</li>
                    <li>T. +39 0431 430144</li>
                    <li>E. hotel@etgroup.info</li>
                </ul>
            </div>
            <div>
                <h4 class="text-[#d4af37] text-[10px] tracking-[0.3em] uppercase mb-6" style="font-family: 'Space Grotesk', sans-serif;">Entdecken</h4>
                <ul class="text-gray-400 text-[11px] tracking-widest font-light space-y-4 uppercase" style="font-family: 'Space Grotesk', sans-serif;">
                    <li><a href="/de/camere" class="hover:text-white transition-colors">Residenzen</a></li>
                    <li><a href="/de/spa" class="hover:text-white transition-colors">Thermen</a></li>
                    <li><a href="/de/ristorante" class="hover:text-white transition-colors">Genuss</a></li>
                </ul>
            </div>
        </div>
        
        <div class="max-w-screen-xl mx-auto px-6 border-t border-white/10 pt-8 text-center">
            <p class="text-[#555] text-[10px] tracking-[0.3em] uppercase" style="font-family: 'Space Grotesk', sans-serif;">
                © 2026 Savoy Beach Hotel & Thermal Spa. Alle Rechte vorbehalten.
            </p>
        </div>
    </footer>
<Concierge/>
<BottomNav/>

    <script>
        const initScripts = () => {
            // 1. ANIMAZIONE ALLO SCROLL
            const elements = document.querySelectorAll<HTMLElement>('h1, h2, h3, p, img:not(.absolute), .group');
            elements.forEach(el => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(30px)';
                el.style.transition = 'opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1)';
            });
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const target = entry.target as HTMLElement;
                        target.style.opacity = '1';
                        target.style.transform = 'translateY(0)';
                        observer.unobserve(target);
                    }
                });
            }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
            elements.forEach(el => observer.observe(el));

            setTimeout(() => {
                elements.forEach(el => {
                    if (el.style.opacity === '0') {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }
                });
            }, 2500);

            // 2. GESTIONE TOCCO LINGUE SU MOBILE
            const langDropdown = document.querySelector('.relative.group.cursor-pointer');
            if (langDropdown && window.innerWidth < 768) {
                // Rimuove hover CSS su mobile
                langDropdown.classList.remove('group'); 
                langDropdown.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const menu = langDropdown.querySelector('.absolute');
                    if (menu) {
                        menu.classList.toggle('opacity-0');
                        menu.classList.toggle('invisible');
                        menu.classList.toggle('translate-y-2');
                        menu.classList.toggle('opacity-100');
                        menu.classList.toggle('visible');
                        menu.classList.toggle('translate-y-0');
                    }
                });
            }
        };
        initScripts();
        document.addEventListener('astro:page-load', initScripts);
    </script>
</body>
</html>