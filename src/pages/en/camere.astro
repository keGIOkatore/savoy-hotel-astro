---
import { ViewTransitions } from 'astro:transitions';
import '../../styles/global.css';
import BottomNav from '../../components/BottomNav.astro';
import Concierge from '../../components/Concierge.astro';

let camere: any[] = [];
try {
    camere = await Astro.glob('../../content/camere/en/*.md');
} catch (error) {}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Residences & Suites | SAVOY Beach Hotel</title>
    
    <ViewTransitions />

    <meta name="description" content="Discover our luxury oceanfront rooms and suites in Bibione. A haven of design and absolute comfort." />
    <link rel="alternate" hreflang="it" href="https://tuosito.com/camere" />
    <link rel="alternate" hreflang="en" href="https://tuosito.com/en/camere" />
    <link rel="alternate" hreflang="de" href="https://tuosito.com/de/camere" />
    <meta property="og:title" content="Residences & Suites | SAVOY Beach Hotel" />
    <meta property="og:description" content="Discover our luxury oceanfront rooms and suites in Bibione." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#050505" />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body class="bg-[#050505] text-[#e0e0e0] antialiased selection:bg-white selection:text-black overflow-x-hidden overscroll-none touch-pan-y">

    <header class="absolute w-full z-50 top-0 py-8 px-6 md:px-12 flex justify-between items-center bg-gradient-to-b from-black/90 via-black/40 to-transparent">
        
        <nav class="hidden md:flex flex-1 justify-start gap-10 text-white text-xs tracking-[0.25em] uppercase font-medium" style="font-family: 'Space Grotesk', sans-serif;">
            <a href="/en/camere" class="text-[#d4af37] border-b border-[#d4af37] pb-1">Residences</a>
            <a href="/en/spa" class="hover:text-[#d4af37] transition-colors duration-500">Thermae</a>
            <a href="/en/ristorante" class="hover:text-[#d4af37] transition-colors duration-500">Dining</a>
        </nav>

        <div class="flex-1 text-center z-10">
            <a href="/en/" class="inline-block text-5xl tracking-[0.3em] uppercase drop-shadow-2xl" style="font-family: 'Cormorant Garamond', serif;">
                <span class="text-white font-light">Sav</span><span class="text-[#d4af37] font-semibold italic">oy</span>
            </a>
        </div>
        
        <div class="absolute right-6 top-10 md:relative md:right-0 md:top-0 md:flex-1 flex justify-end items-center gap-8 z-20">
            <div class="relative group cursor-pointer">
                <div class="flex items-center gap-2 text-white font-medium text-xs tracking-[0.2em] uppercase pb-1 border-b border-[#d4af37]" style="font-family: 'Space Grotesk', sans-serif;">
                    <span>EN</span>
                    <svg class="w-3 h-3 text-[#d4af37]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
                
                <div class="absolute right-0 mt-2 w-36 bg-black/90 backdrop-blur-xl border border-white/10 rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 overflow-hidden shadow-2xl">
                    <a href="/camere" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-white/70 hover:text-white hover:bg-white/10 transition-colors border-b border-white/5">Italiano</a>
                    <a href="/en/camere" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-[#d4af37] bg-white/5 border-b border-white/5 font-bold">English</a>
                    <a href="/de/camere" class="block px-4 py-3 text-[10px] tracking-[0.2em] uppercase text-white/70 hover:text-white hover:bg-white/10 transition-colors border-b border-white/5">Deutsch</a>
                </div>
            </div>
            
            <a href="https://www.booking.com/Share-rV0ICW" target="_blank" class="hidden md:block bg-gradient-to-r from-[#d4af37] to-[#c5a028] text-black px-10 py-4 text-xs tracking-[0.3em] uppercase font-bold shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:shadow-[0_0_30px_rgba(212,175,55,0.8)] hover:scale-105 transition-all duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                Book
            </a>
        </div>
    </header>

    <section class="relative h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Residences" class="absolute inset-0 w-full h-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">Your Refuge</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-6" style="font-family: 'Cormorant Garamond', serif;">
                <i>The</i> Residences.
            </h1>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-xl mx-auto">
        {camere.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                We are preparing our elegant suites.
            </div>
        ) : (
            <div class="space-y-40">
                {camere.map((camera, index) => {
                    const Content = camera.Content;
                    return (
                        <div class:list={['flex flex-col items-center gap-16', index % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row']}>
                            <div class="md:w-3/5 relative group overflow-hidden">
                                <img src={camera.frontmatter.image} alt={camera.frontmatter.title} class="w-full h-[50vh] md:h-[70vh] object-cover opacity-90 transition duration-1000 scale-105 group-hover:scale-100" />
                            </div>
                            <div class="md:w-2/5 flex flex-col justify-center">
                                <h2 class="text-4xl md:text-5xl text-white font-light mb-4" style="font-family: 'Cormorant Garamond', serif;">
                                    {camera.frontmatter.title}
                                </h2>
                                <p class="text-[#d4af37] text-[10px] tracking-[0.3em] uppercase mb-8" style="font-family: 'Space Grotesk', sans-serif;">
                                    Starting from € {camera.frontmatter.prezzo} per night
                                </p>
                                <div class="text-gray-400 font-light text-sm leading-relaxed mb-10" style="font-family: 'Space Grotesk', sans-serif;">
                                    <Content />
                                </div>
                                
                                <div class="mt-10">
                                    <a href="https://www.booking.com/Share-rV0ICW" target="_blank" class="group inline-flex items-center gap-6 px-8 py-4 border border-white/20 active:border-[#d4af37] md:hover:border-[#d4af37] active:bg-white/5 transition-all duration-300 cursor-pointer">
                                        <span class="text-white/80 group-active:text-[#d4af37] md:group-hover:text-[#d4af37] text-[10px] tracking-[0.3em] uppercase font-light transition-colors duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                                            Check Availability
                                        </span>
                                        <svg class="w-4 h-4 text-white/40 group-active:text-[#d4af37] md:group-hover:text-[#d4af37] transform group-active:translate-x-2 md:group-hover:translate-x-2 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                    </a>
                                </div>
                                
                            </div>
                        </div>
                    )
                })}
            </div>
        )}
    </section>

    <footer class="py-12 border-t border-white/10 text-center">
        <p class="text-[#555] text-xs tracking-[0.3em] uppercase" style="font-family: 'Space Grotesk', sans-serif;">
            © 2026 Savoy Beach Hotel.
        </p>
    </footer>
<Concierge/>
<BottomNav/>

    <script>
        const initScrollReveal = () => {
            const elements = document.querySelectorAll<HTMLElement>('h1, h2, h3, p, img:not(.absolute), .group');
            elements.forEach(el => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(30px)';
                el.style.transition = 'opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1)';
            });
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const target = entry.target as HTMLElement;
                        target.style.opacity = '1';
                        target.style.transform = 'translateY(0)';
                        observer.unobserve(target);
                    }
                });
            }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
            elements.forEach(el => observer.observe(el));
        };
        initScrollReveal();
        document.addEventListener('astro:page-load', initScrollReveal);
    </script>
</body>
</html>