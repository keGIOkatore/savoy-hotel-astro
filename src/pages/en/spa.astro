---
import orariData from '../../data/orari.json';
// @ts-ignore
import OrarioBadge from '../../components/OrarioBadge.astro';
// @ts-ignore
import BaseLayout from '../../layouts/BaseLayout.astro';

let trattamenti: any[] = [];
try { trattamenti = await Astro.glob('../../content/spa/en/*.md'); } catch (error) {}
---

<BaseLayout title="Bibione Thermae" description="Discover the Savoy Beach Hotel spa: an oasis of wellness with exclusive treatments and luxury environments in Bibione." lang="en" currentPath="/spa">

    <section class="relative h-[60vh] flex flex-col justify-center items-center overflow-hidden text-center px-4 border-b border-white/10">
        <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Spa Savoy" class="absolute inset-0 w-full h-full object-cover opacity-30 pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#050505]"></div>
        
        <div class="relative z-10 mt-24">
            <p class="text-[#d4af37] text-xs tracking-[0.3em] uppercase mb-4" style="font-family: 'Space Grotesk', sans-serif;">A World of Relaxation</p>
            <h1 class="text-6xl md:text-8xl text-white font-light leading-none mb-6" style="font-family: 'Cormorant Garamond', serif;">
                <i>The</i> Spa.
            </h1>
        </div>
    </section>

    <section class="py-32 px-6 max-w-screen-xl mx-auto">
        {trattamenti.length === 0 ? (
            <div class="text-center text-gray-500 font-light tracking-widest uppercase text-xs" style="font-family: 'Space Grotesk', sans-serif;">
                Preparing our treatments.
            </div>
        ) : (
            <div class="space-y-40">
                {trattamenti.map((trattamento, index) => {
                    const Content = trattamento.Content;
                    return (
                        <div class:list={['group flex flex-col items-center gap-12 md:gap-16', index % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row']}>
                            <div class="md:w-3/5 w-full relative group overflow-hidden">
                                <img loading="lazy" src={trattamento.frontmatter.image} alt={trattamento.frontmatter.title} class="w-full h-[40vh] md:h-[70vh] object-cover opacity-80 group-hover:opacity-100 transition-all duration-[5500ms] ease-out scale-[1.03] group-hover:scale-100 pointer-events-none" />
                            </div>
                            
                            <div class="md:w-2/5 w-full flex flex-col justify-center">
                                <h2 class="text-4xl md:text-5xl lg:text-6xl text-white font-light mb-4" style="font-family: 'Cormorant Garamond', serif;">
                                    {trattamento.frontmatter.title}
                                </h2>
                                
                                <div class="flex flex-wrap items-center gap-4 mb-8">
                                    <span class="px-3 py-1 border border-white/20 text-[9px] md:text-[11px] tracking-widest uppercase text-gray-300" style="font-family: 'Space Grotesk', sans-serif;">
                                        {trattamento.frontmatter.durata} min
                                    </span>
                                </div>
                                
                                <div class="text-gray-400 font-light text-sm md:text-lg lg:text-xl leading-relaxed mb-10 prose prose-invert" style="font-family: 'Space Grotesk', sans-serif;">
                                    <Content />
                                </div>
                                
                                <div class="mt-4">
                                    <a href={`https://wa.me/390431430144?text=Dear%20Concierge,%20I%20would%20like%20to%20book%20the%20treatment:%20${trattamento.frontmatter.title}`} target="_blank" class="group/btn inline-flex items-center justify-center md:justify-start gap-4 md:gap-6 px-4 py-3 md:px-8 md:py-4 border border-white/20 active:border-[#d4af37] md:hover:border-[#d4af37] transition-all duration-300 w-fit">
                                        <span class="whitespace-nowrap text-white/80 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] text-[9px] md:text-xs tracking-[0.2em] md:tracking-[0.3em] uppercase font-bold transition-colors duration-300" style="font-family: 'Space Grotesk', sans-serif;">
                                            Book Experience
                                        </span>
                                        <svg class="w-4 h-4 md:w-5 md:h-5 text-white/40 group-active/btn:text-[#d4af37] md:group-hover/btn:text-[#d4af37] transform group-active/btn:translate-x-2 md:group-hover/btn:translate-x-2 transition-all duration-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    )
                })}
            </div>
        )}
    </section>
</BaseLayout>